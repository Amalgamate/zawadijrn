# Dependencies
node_modules/
**/node_modules/
server/node_modules/

# Build outputs
build/
dist/
**/dist/
**/build/
.next/
out/
public/build/
*.tsbuildinfo

# Environment & Secrets (CRITICAL)
.env
.env.local
.env.*.local
*.env
server/.env

# Prisma
prisma/*.db
prisma/*.db-journal
.prisma/
server/node_modules/.prisma/

# Logs
logs/
*.log
!logs/.gitkeep
!server/logs/.gitkeep
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data / PIDs
pids/
*.pid
*.pid.lock

# Coverage / tests
coverage/
.nyc_output/
*.lcov
junit.xml

# Temporary & cache
tmp/
temp/
_cache/
*.tmp
*.temp
.cache/

# Editor & OS
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# Test Scripts
test-puppeteer*.js
server/test-puppeteer*.js
verify-restoration.js
debug_zamzam.js

# Archive folders — old dev scripts, not deployed
_archive/
server/_archive/

# Misc local temp/backup
temp_login.json
_backup_removed_files/
backup_removed/
.history/

# Data files (avoid committing local datasets)
*.csv
*.xls
*.xlsx

# Sensitive credential files
teacher-credentials.json
*-credentials.json
server/prisma/schema.live.prisma

#
# PROTECTED SNAPSHOTS (do not remove during cleanup)
!USERS_SNAPSHOT__PROTECTED__.txt
backups/
server/backups/

# WhatsApp session data (auth credentials, never commit)
server/.wwebjs_auth/
