# ============================================
# ZAWADI SMS - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# MARK: ALL "REQUIRED" VALUES ARE CRITICAL FOR SECURITY

# ============================================
# APPLICATION (REQUIRED)
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE (REQUIRED)
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/zawadi_sms

# Direct Postgres URL (required by Prisma for migrations; required for backups if DATABASE_URL is a pooler e.g. Supabase :6543 / pgbouncer)
# DIRECT_URL=postgresql://user:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Optional: backup/restore use pg_dump and psql. If the API process has no PostgreSQL on PATH (common when started from an IDE), set the bin folder or full executables:
# PGBIN=C:\Program Files\PostgreSQL\17\bin
# PG_DUMP=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe
# PSQL=C:\Program Files\PostgreSQL\17\bin\psql.exe

# ============================================
# AUTHENTICATION (REQUIRED - SECURITY CRITICAL)
# ============================================
# Generate strong secrets: openssl rand -base64 32
# Minimum 32 characters. Use different values for each environment
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_generated_securely
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_long_generated_securely
JWT_EXPIRES_IN=7d

# ============================================
# FRONTEND CONFIGURATION (REQUIRED)
# ============================================
# Frontend application URL
FRONTEND_URL=http://localhost:3000

# API base URL (for frontend to consume)
API_URL=http://localhost:5000/api

# ============================================
# SUBDOMAIN/MULTI-TENANT CONFIGURATION (Optional)
# ============================================
DEPLOYMENT_DOMAIN=elimcrown.co.ke
SUBDOMAIN_ENABLED=true
SUBDOMAIN_CACHE_TTL=600
SUBDOMAIN_RESERVED_WORDS=www,api,mail,admin,support,blog,contact,help,docs,status

# ============================================
# EMAIL CONFIGURATION (Optional - choose one)
# ============================================

# Option 1: Resend.com (Recommended for production)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# Option 2: SMTP (Legacy/Fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM="Zawadi SMS <your_email@gmail.com>"

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================
SMS_PROVIDER=mobilesasa
MOBILESASA_API_KEY=your_mobilesasa_api_key
MOBILESASA_SENDER_ID=ZAWADI

# ============================================
# WHATSAPP CONFIGURATION (Optional)
# ============================================
WHATSAPP_API_URL=https://graph.instagram.com/v18.0/your_phone_id/messages
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ============================================
# SECURITY SETTINGS (Production Recommended)
# ============================================
# Enable rate limiting across all endpoints
RATE_LIMIT_ENABLED=true

# Use secure cookies (requires HTTPS)
SECURE_COOKIES=false

# CORS origin (restrict to specific domains in production)
CORS_ORIGIN=http://localhost:3000

# Content Security Policy
CSP_ENABLED=true

# HTTPS only enforcement
HTTPS_ONLY=false

# ============================================
# LOGGING & MONITORING
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Sentry error tracking (optional)
SENTRY_DSN=

# ============================================
# CLOUD STORAGE
# ============================================
# File uploads are handled via Supabase Storage.
# Make sure your Supabase bucket 'documents' exists and is configured.
# SUPABASE_SERVICE_ROLE_KEY is required for server-side uploads.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# DEVELOPMENT FEATURES (Remove in Production)
# ============================================
# Enable development routes and utilities
ENABLE_DEV_ROUTES=true

# ============================================
# 🔒 SECURITY CHECKLIST FOR PRODUCTION
# ============================================
# Before deploying to production:
# 1. Generate strong JWT secrets: openssl rand -base64 32
#    - Use different values for JWT_SECRET and JWT_REFRESH_SECRET
# 2. URLs must use HTTPS (https://... not http://...)
# 3. Set RATE_LIMIT_ENABLED=true
# 4. Set SECURE_COOKIES=true (only with HTTPS)
# 5. Set HTTPS_ONLY=true
# 6. Restrict CORS_ORIGIN to your specific domain
# 7. Keep all API keys and secrets out of version control
# 8. Use a .env file in production (not committed to git)
# 9. Enable logging and monitoring for security events
# 10. Test authentication and authorization thoroughly
# 11. Enable CSP_ENABLED=true
# 12. Rotate secrets regularly
# 13. Use environment-specific values for dev/staging/prod
# 14. Disable ENABLE_DEV_ROUTES in production
# 15. Set LOG_LEVEL=error in production (not info/debug)
