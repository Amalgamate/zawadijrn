model FeeStructure {
  id           String             @id @default(uuid())
  name         String
  description  String?
  /// FIX: grade and term are optional — a school-wide structure can omit both.
  /// The @@unique constraint uses nulls-distinct semantics in PostgreSQL so
  /// multiple grade=null / term=null rows CAN coexist as long as (name, academicYear)
  /// or the composite (grade, term, academicYear) differs.
  grade        Grade?
  term         Term?
  academicYear Int
  active       Boolean            @default(true)
  mandatory    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdBy    String?
  archived     Boolean            @default(false)
  archivedAt   DateTime?
  archivedBy   String?
  invoices     FeeInvoice[]
  feeItems     FeeStructureItem[]
  creator      User?              @relation("CreatedFeeStructures", fields: [createdBy], references: [id])

  @@unique([grade, term, academicYear])
  @@index([academicYear])
  @@map("fee_structures")
}
