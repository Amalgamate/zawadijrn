  createdAt     DateTime          @default(now())
  fromStore     InventoryStore?   @relation("FromStore", fields: [fromStoreId], references: [id])
  item          InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  toStore       InventoryStore?   @relation("ToStore", fields: [toStoreId], references: [id])

  @@index([itemId])
  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([date])
  @@map("stock_movements")
}

model StockRequisition {
  id            String                 @id @default(uuid())
  requisitionNo String                 @unique
  requestedById String
