  createdBy   User            @relation("LMSCreatedCourses", fields: [createdById], references: [id])
  enrollments LMSEnrollment[]

  @@index([createdById])
  @@index([subject])
  @@index([grade])
  @@index([status])
  @@map("lms_courses")
}

model LMSContent {
  id           String        @id @default(uuid())
  courseId     String
  title        String
  description  String?
  type         ContentType
  url          String
  duration     Int?
  fileSize     Int?
  order        Int           @default(1)
  uploadedById String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  archived     Boolean       @default(false)
  course       LMSCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  uploadedBy   User          @relation("LMSUploadedContent", fields: [uploadedById], references: [id])
