  @@index([sku])
  @@map("inventory_items")
}

model StockMovement {
  id            String            @id @default(uuid())
  itemId        String
  fromStoreId   String?
  toStoreId     String?
  quantity      Decimal           @db.Decimal(10, 2)
  type          StockMovementType
  reference     String?
  description   String?
  performedById String?
