  @@unique([teacherId, grade, learningArea, term, academicYear])
  @@unique([teacherId, grade, learningArea, term, academicYear], map: "schemes_of_work_teacherId_grade_learningArea_term_academic_key")
  @@index([grade, term, academicYear])
  @@index([teacherId])
  @@index([status])
  @@map("schemes_of_work")
}

