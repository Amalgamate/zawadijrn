  @@index([courseId])
  @@index([uploadedById])
  @@index([type])
  @@map("lms_content")
}

model LMSEnrollment {
  id           String           @id @default(uuid())
  courseId     String
  learnerId    String
  enrolledById String
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  unenrolledAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  archived     Boolean          @default(false)
  course       LMSCourse        @relation(fields: [courseId], references: [id])
  enrolledBy   User             @relation("LMSEnrolledBy", fields: [enrolledById], references: [id])
  learner      Learner          @relation("LMSEnrolledLearners", fields: [learnerId], references: [id])
  progress     LMSProgress[]

  @@unique([courseId, learnerId])
  @@index([courseId])
  @@index([learnerId])
  @@index([enrolledById])
  @@index([status])
  @@map("lms_enrollments")
}

model LMSProgress {
  id             String        @id @default(uuid())
  enrollmentId   String
  contentId      String
  completed      Boolean       @default(false)
  progress       Int           @default(0)
  timeSpent      Int           @default(0)
  lastAccessedAt DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  content        LMSContent    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  enrollment     LMSEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, contentId])
  @@index([enrollmentId])
  @@index([contentId])
  @@map("lms_progress")
}

