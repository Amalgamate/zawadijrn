  branchId      String?
  basicSalary   Decimal       @db.Decimal(10, 2)
  allowances    Json?         // Map of label -> amount
  deductions    Json?         // Map of label -> amount
  netSalary     Decimal       @db.Decimal(10, 2)
  status        PayrollStatus @default(DRAFT)
  generatedAt   DateTime      @default(now())
  generatedBy   String?
  paidAt        DateTime?
  reference     String?       // Payment ref
  notes         String?
  
  user          User          @relation(fields: [userId], references: [id])
  school        School?       @relation(fields: [schoolId], references: [id])

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
  @@map("payroll_records")
}

model StaffDocument {
  id           String   @id @default(uuid())
  userId       String
  schoolId     String?
  branchId     String?
  name         String
  url          String
  type         String   // PDF, Image, etc
  category     String   @default("CONTRACT") // CONTRACT, ID, KRA, QUALIFICATION
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school       School?  @relation(fields: [schoolId], references: [id])

  @@index([userId])
  @@index([schoolId])
  @@map("staff_documents")
}

model PerformanceReview {
  id                String   @id @default(uuid())
  userId            String
  reviewerId        String
  schoolId          String?
  branchId          String?
  reviewDate        DateTime @default(now())
  periodStart       DateTime
  periodEnd         DateTime
  technicalRating   Int      @default(3) // 1-5 scale
  behavioralRating  Int      @default(3) // 1-5 scale
  collaborationRating Int    @default(3) // 1-5 scale
  overallRating     Decimal  @db.Decimal(3, 2)
  comments          String?
  goals             Json?    // Array of { goal: string, status: string }
  status            String   @default("COMPLETED") // DRAFT, COMPLETED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation("StaffReviews", fields: [userId], references: [id])
  reviewer          User     @relation("ConductedReviews", fields: [reviewerId], references: [id])
  school            School?  @relation(fields: [schoolId], references: [id])

  @@index([userId])
  @@index([reviewerId])
  @@index([schoolId])
  @@map("performance_reviews")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  GENERATED
  PAID
  VOID
}

enum AccountType {
  ASSET_RECEIVABLE
  ASSET_CASH
  ASSET_NON_CURRENT
  LIABILITY_PAYABLE
  LIABILITY_CURRENT
  LIABILITY_NON_CURRENT
  EQUITY
  REVENUE
  EXPENSE
  EXPENSE_DEPRECIATION
}

enum JournalType {
  SALES
  PURCHASE
  CASH
  BANK
  GENERAL
}

model Account {
  id            String        @id @default(uuid())
  code          String        @unique // e.g., "101100"
  name          String        // e.g., "Main Bank Account"
  type          AccountType
  schoolId      String?
  branchId      String?
  parentId      String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  parent        Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]     @relation("AccountHierarchy")
  journalItems  JournalItem[]
  expenses      Expense[]
  bankStatements BankStatement[]
  school       School?       @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("accounts")
}

model Journal {
  id            String        @id @default(uuid())
  name          String
  code          String        @unique // e.g., "BNK1"
  type          JournalType
  schoolId      String?
  branchId      String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  entries       JournalEntry[]
  school        School?        @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("journals")
}

model JournalEntry {
  id            String        @id @default(uuid())
  date          DateTime      @default(now())
  reference     String?       // e.g., "INV/2026/001"
  journalId     String
  schoolId      String?
  branchId      String?
  status        String        @default("DRAFT") // DRAFT, POSTED, CANCELLED
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  journal       Journal       @relation(fields: [journalId], references: [id])
  items         JournalItem[]
  school        School?       @relation(fields: [schoolId], references: [id])

  @@index([journalId])
  @@index([date])
  @@index([schoolId])
  @@map("journal_entries")
}

model JournalItem {
  id            String        @id @default(uuid())
  entryId       String
  accountId     String
  debit         Decimal       @default(0) @db.Decimal(15, 2)
  credit        Decimal       @default(0) @db.Decimal(15, 2)
  label         String?       // Transaction line description
  createdAt     DateTime      @default(now())

  entry         JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account           Account       @relation(fields: [accountId], references: [id])
  bankStatementLine BankStatementLine?

  @@index([entryId])
  @@index([accountId])
  @@map("journal_items")
}

model FiscalYear {
  id            String        @id @default(uuid())
  name          String        @unique // e.g., "FY 2026"
  startDate     DateTime
  endDate       DateTime
  status        String        @default("OPEN") // OPEN, CLOSED
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("fiscal_years")
}
model Vendor {
  id        String    @id @default(uuid())
  name      String    @unique
  schoolId  String?
  branchId  String?
  contact   String?
  email     String?
  phone     String?
  address   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
  school    School?   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("vendors")
}

model Expense {
  id            String    @id @default(uuid())
  date          DateTime  @default(now())
  amount        Decimal   @db.Decimal(15, 2)
  description   String
  category      String    // e.g., "Electricity", "Water", "Repair"
  schoolId      String?
  branchId      String?
  vendorId      String?
  accountId     String    // The ledger account for this expense (e.g., 5100)
  paymentMethod PaymentMethod @default(CASH)
  reference     String?   // Receipt/Invoice number
  status        String    @default("PAID") // PAID, PENDING
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  account       Account   @relation(fields: [accountId], references: [id])
  school        School?   @relation(fields: [schoolId], references: [id])

  @@index([vendorId])
  @@index([accountId])
  @@index([schoolId])
  @@map("expenses")
}

model BankStatement {
  id            String               @id @default(uuid())
  accountId     String               // Bank Account
  dateRange     String?              // e.g., "Jan 2026"
  schoolId      String?
  branchId      String?
  startingBalance Decimal            @db.Decimal(15, 2)
  endingBalance   Decimal            @db.Decimal(15, 2)
  status        String               @default("DRAFT") // DRAFT, RECONCILED
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  account       Account              @relation(fields: [accountId], references: [id])
  lines         BankStatementLine[]
  school        School?              @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("bank_statements")
}

model BankStatementLine {
  id            String         @id @default(uuid())
  statementId   String
  date          DateTime
  description   String
  amount        Decimal        @db.Decimal(15, 2)
  reference     String?
  status        String         @default("UNRECONCILED") // UNRECONCILED, MATCHED
  journalItemId String?        @unique // Linked ledger entry
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  statement     BankStatement  @relation(fields: [statementId], references: [id], onDelete: Cascade)
  journalItem   JournalItem?   @relation(fields: [journalItemId], references: [id])

  @@index([statementId])
  @@map("bank_statement_lines")
}

// ============================================
// INVENTORY & ASSET MANAGEMENT
// ============================================

enum InventoryItemType {
  CONSUMABLE
  ASSET
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum RequisitionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  FULFILLED
  CANCELLED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  BROKEN
  REJECTED
}

model InventoryCategory {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  parentId    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  parent      InventoryCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    InventoryCategory[] @relation("CategoryHierarchy")
  items       InventoryItem[]

  @@map("inventory_categories")
}

model InventoryStore {
  id          String         @id @default(uuid())
  name        String         @unique
  code        String?        // e.g., "WH-MAIN"
  location    String?
  schoolId    String?
  branchId    String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  movementsFrom StockMovement[] @relation("FromStore")
  movementsTo   StockMovement[] @relation("ToStore")
  fixedAssets   FixedAsset[]
  school        School?         @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("inventory_stores")
}

model InventoryItem {
  id              String            @id @default(uuid())
  name            String            @unique
  sku             String?
  description     String?
  categoryId      String?
  schoolId        String?
  branchId        String?
  type            InventoryItemType @default(CONSUMABLE)
  unitOfMeasure   String            @default("PCS") // PCS, KG, LTR, PKT
  reorderLevel    Decimal           @default(0) @db.Decimal(10, 2)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  category        InventoryCategory? @relation(fields: [categoryId], references: [id])
  movements       StockMovement[]
  requisitionItems StockRequisitionItem[]
  fixedAssets     FixedAsset[]
  school          School?            @relation(fields: [schoolId], references: [id])

  @@index([sku])
  @@index([schoolId])
  @@map("inventory_items")
}

model StockMovement {
  id            String            @id @default(uuid())
  itemId        String
  schoolId      String?
  branchId      String?
  fromStoreId   String?
  toStoreId     String?
  quantity      Decimal           @db.Decimal(10, 2)
  type          StockMovementType
  reference     String?           // e.g., PO number, Requisition ID
  description   String?
  performedById String?
  date          DateTime          @default(now())
  createdAt     DateTime          @default(now())

  item          InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromStore     InventoryStore?   @relation("FromStore", fields: [fromStoreId], references: [id])
  toStore       InventoryStore?   @relation("ToStore", fields: [toStoreId], references: [id])
  school        School?           @relation(fields: [schoolId], references: [id])

  @@index([itemId])
  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([date])
  @@index([schoolId])
  @@map("stock_movements")
}

model StockRequisition {
  id            String            @id @default(uuid())
  requisitionNo String            @unique // e.g., "REQ/2026/001"
  schoolId      String?
  branchId      String?
  requestedById String
  department    String?           // or Class
  priority      String            @default("NORMAL") // NORMAL, URGENT
  status        RequisitionStatus @default(PENDING)
  notes         String?
  requiredDate  DateTime?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requestedBy   User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  items         StockRequisitionItem[]
  school        School?           @relation(fields: [schoolId], references: [id])

  @@index([status])
  @@index([schoolId])
  @@map("stock_requisitions")
}

model StockRequisitionItem {
  id            String           @id @default(uuid())
  requisitionId String
  itemId        String
  quantity      Decimal          @db.Decimal(10, 2)
  fulfilledQty  Decimal          @default(0) @db.Decimal(10, 2)
  
  requisition   StockRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  item          InventoryItem    @relation(fields: [itemId], references: [id])

  @@map("stock_requisition_items")
}

model FixedAsset {
  id              String         @id @default(uuid())
  assetCode       String         @unique // e.g., "FA-LPT-001"
  itemId          String?        // Link to generic item type
  schoolId        String?
  branchId        String?
  name            String
  description     String?
  serialNumber    String?
  model           String?
  manufacturer    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal?       @db.Decimal(15, 2)
  warrantyExpiry  DateTime?
  condition       AssetCondition @default(NEW)
  location        String?        // Physical room
  currentStoreId  String?        // If in a store
  status          String         @default("ACTIVE") // ACTIVE, RETIRED, LOST, BROKEN
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  item            InventoryItem? @relation(fields: [itemId], references: [id])
  currentStore    InventoryStore? @relation(fields: [currentStoreId], references: [id])
  assignments     AssetAssignment[]
  school          School?         @relation(fields: [schoolId], references: [id])

  @@index([assetCode])
  @@index([schoolId])
  @@map("fixed_assets")
}

model AssetAssignment {
  id              String         @id @default(uuid())
  assetId         String
  assignedToId    String?        // User (Staff/Teacher)
  assignedToClassId String?      // Class
  assignedAt      DateTime       @default(now())
  expectedReturn  DateTime?
  returnedAt      DateTime?
  conditionOnAssigned AssetCondition
  conditionOnReturned AssetCondition?
  notes           String?
  
  asset           FixedAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedTo      User?          @relation("AssetUser", fields: [assignedToId], references: [id])
  assignedToClass Class?         @relation("AssetClass", fields: [assignedToClassId], references: [id])

  @@index([assetId])
  @@map("asset_assignments")
}
