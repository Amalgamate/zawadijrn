model FeeComment {
  id          String      @id @default(uuid())
  invoiceId   String
  type        CommentType @default(NOTE)
  body        String
  isInternal  Boolean     @default(true)
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archived    Boolean     @default(false)

  invoice   FeeInvoice @relation(fields: [invoiceId],   references: [id], onDelete: Cascade)
  createdBy User       @relation("FeeCommentAuthor",    fields: [createdById], references: [id])
  pledge    FeePledge?

  @@index([invoiceId])
  @@index([type])
  @@index([createdAt])
  @@map("fee_comments")
}

model FeePledge {
  id              String       @id @default(uuid())
  invoiceId       String
  commentId       String?      @unique
  pledgedAmount   Decimal      @db.Decimal(10, 2)
  pledgeDate      DateTime
  status          PledgeStatus @default(PENDING)
  fulfilledAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  reminderSentAt  DateTime?
  reminderCount   Int          @default(0)
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  archived        Boolean      @default(false)

  invoice   FeeInvoice  @relation(fields: [invoiceId],  references: [id], onDelete: Cascade)
  comment   FeeComment? @relation(fields: [commentId],  references: [id])
  createdBy User        @relation("FeePledgeCreator",   fields: [createdById], references: [id])

  @@index([invoiceId])
  @@index([pledgeDate])
  @@index([status])
  @@map("fee_pledges")
}

model FeeWaiver {
  id              String        @id @default(uuid())
  invoiceId       String
  amountWaived    Decimal       @db.Decimal(10, 2)
  reason          String
  waiverCategory  String?       @default("OTHER")
  status          WaiverStatus  @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  archived        Boolean       @default(false)

  invoice    FeeInvoice @relation(fields: [invoiceId],    references: [id], onDelete: Cascade)
  createdBy  User       @relation("FeeWaiverCreator",     fields: [createdById], references: [id])
  approvedBy User?      @relation("FeeWaiverApprover",    fields: [approvedById], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
  @@map("fee_waivers")
}

model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR, WAIVER
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("user_notifications")
}


// ============================================================================
// TERTIARY MODULE ENUMS & MODELS
// ============================================================================

enum TertiaryLevel {
  CERTIFICATE
  DIPLOMA
  DEGREE
  POSTGRADUATE
}

model TertiaryDepartment {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  headOfDept  String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  programs    TertiaryProgram[]
  units       TertiaryUnit[]
}

model TertiaryProgram {
  id           String             @id @default(uuid())
  code         String             @unique
  name         String
  level        TertiaryLevel
  departmentId String
  department   TertiaryDepartment @relation(fields: [departmentId], references: [id])
  durationYears Int               @default(4)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model TertiaryUnit {
  id          String   @id @default(uuid())
  code        String   @unique  // e.g. BIT 101
  name        String
  creditHours Int      @default(3)
  year        Int
  semester    Int
  departmentId String
  department   TertiaryDepartment @relation(fields: [departmentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments  UnitEnrollment[]
  results      UnitResult[]
}

model UnitEnrollment {
  id        String   @id @default(uuid())
  studentId String
  unitId    String
  semester  Int
  year      Int
  createdAt DateTime @default(now())
  
  unit      TertiaryUnit @relation(fields: [unitId], references: [id])
}

model UnitResult {
  id          String   @id @default(uuid())
  studentId   String
  unitId      String
  cats        Float  // Continuous Assessment Tests (30%)
  exam        Float  // Final Exam (70%)
  total       Float
  grade       String // A, B+, B, C+, C, D+, D, E
  gradePoints Float  // GPA points
  semester    Int
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit        TertiaryUnit @relation(fields: [unitId], references: [id])
}

// ============================================================================
// M-PESA DARAJA API ENUMS & MODELS
// ============================================================================

enum MpesaStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum MpesaTransactionType {
  COLLECTION
  PAYOUT
}

model MpesaTransaction {
  id                String               @id @default(uuid())
  type              MpesaTransactionType @default(COLLECTION)
  merchantRequestId String?              @unique
  checkoutRequestId String?              @unique
  amount            Decimal              @db.Decimal(10, 2)
  phoneNumber       String?              // Source for Collection, Destination for Payout
  status            MpesaStatus          @default(PENDING)
  resultCode        Int?
  resultDesc        String?
  transactionId     String?              @unique // M-Pesa Receipt Number from Callback
  metadata          Json?
  studentId         String?              // Linked to collection
  invoiceId         String?              // Linked to collection
  staffId           String?              // Linked to payout (payroll)
  payrollRecordId   String?              // Linked to payout (payroll)
  externalId        String?              @unique // Kopo Kopo ID or custom reference
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  callbacks         MpesaCallback[]
}

model MpesaCallback {
  id              String           @id @default(uuid())
  transactionId   String
  rawBody         Json
  createdAt       DateTime         @default(now())

  transaction     MpesaTransaction @relation(fields: [transactionId], references: [id])
  @@map("mpesa_callbacks")
}

model SystemChangelog {
  id          String   @id @default(uuid())
  version     String
  title       String
  description String
  type        ChangelogType @default(FEATURE)
  tags        String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_changelogs")
}

enum ChangelogType {
  FEATURE
  FIX
  IMPROVEMENT
  SECURITY
}

// ============================================================================
// M-PESA UNMATCHED PAYMENTS — Buy Goods Till organic payments awaiting assignment
// ============================================================================

enum UnmatchedPaymentStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model UnmatchedPayment {
  id              String                 @id @default(uuid())
  phone           String                 // Normalized 254XXXXXXXXX format
  amount          Decimal                @db.Decimal(10, 2)
  receiptNo       String                 @unique // M-Pesa receipt / Kopo reference
  transactionDate DateTime               @default(now())
  status          UnmatchedPaymentStatus @default(PENDING)
  note            String?                // Admin note on DISMISSED reason
  rawPayload      Json                   // Full webhook body for audit

  // Resolution fields — set when admin assigns
  resolvedLearnerId String?
  resolvedInvoiceId String?
  resolvedBy        String?
  resolvedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([phone])
  @@map("unmatched_payments")
}
