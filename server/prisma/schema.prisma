generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String                   @id @default(uuid())
  email                     String                   @unique
  username                  String?                  @unique
  password                  String
  firstName                 String
  lastName                  String
  middleName                String?
  phone                     String?
  role                      UserRole                 @default(TEACHER)
  status                    UserStatus               @default(ACTIVE)
  archived                  Boolean                  @default(false)
  archivedAt                DateTime?
  archivedBy                String?
  emailVerificationToken    String?
  emailVerificationSentAt   DateTime?
  phoneVerificationCode     String?
  phoneVerificationSentAt   DateTime?
  staffId                   String?                  @unique
  idCardPhoto               String?
  idCardIssued              DateTime?
  idCardExpiry              DateTime?
  lastLogin                 DateTime?
  emailVerified             Boolean                  @default(false)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  loginAttempts             Int                      @default(0)
  lockedUntil               DateTime?
  passwordResetToken        String?
  passwordResetExpiry       DateTime?
  profilePicture            String?
  bankAccountName           String?
  bankAccountNumber         String?
  bankName                  String?
  basicSalary               Decimal?                 @db.Decimal(10, 2)
  employmentType            String?                  @default("PERMANENT")
  joinedAt                  DateTime?                @default(now())
  kraPin                    String?
  nhifNumber                String?
  nssfNumber                String?
  subject                   String?
  gender                    String?
  institutionType           InstitutionType          @default(PRIMARY_CBC)
  shifNumber                String?
  housingLevyExempt         Boolean                  @default(false)
  createdAggregationConfigs AggregationConfig[]
  assignedAssets            AssetAssignment[]        @relation("AssetUser")
  attendancesMarked         Attendance[]             @relation("AttendanceMarker")
  biometricCredentials      BiometricCredential[]
  changeHistory             ChangeHistory[]
  schedules                 ClassSchedule[]          @relation("TeacherSchedules")
  classesAsTeacher          Class[]                  @relation("ClassTeacher")
  recordedCoCurricular      CoCurricularActivity[]   @relation("RecorderCoCurricular")
  createdContactGroups      ContactGroup[]           @relation("CreatedContactGroups")
  assessedCoreCompetencies  CoreCompetency[]         @relation("AssessorCoreCompetencies")
  uploadedDocuments         Document[]
  createdEvents             Event[]                  @relation("EventCreator")
  recordedPayments          FeePayment[]             @relation("RecordedPayments")
  feeComments               FeeComment[]             @relation("FeeCommentAuthor")
  feePledges                FeePledge[]              @relation("FeePledgeCreator")
  feeWaivers                FeeWaiver[]              @relation("FeeWaiverCreator")
  approvedFeeWaivers        FeeWaiver[]              @relation("FeeWaiverApprover")
  createdFeeStructures      FeeStructure[]           @relation("CreatedFeeStructures")
  waivedFines               Fine[]                   @relation("FineWaivers")
  formativeAssessments      FormativeAssessment[]    @relation("TeacherFormativeAssessments")
  learners                  Learner[]                @relation("ParentLearners")
  approvedLeaves            LeaveRequest[]           @relation("ApprovedLeaves")
  leaveRequests             LeaveRequest[]           @relation("UserLeaves")
  libraryMember             LibraryMember?
  uploadedLMSContent        LMSContent[]             @relation("LMSUploadedContent")
  lmsCourses                LMSCourse[]              @relation("LMSCreatedCourses")
  lmsEnrollments            LMSEnrollment[]          @relation("LMSEnrolledBy")
  createdNotices            Notice[]                 @relation("NoticeAuthor")
  payrollRecords            PayrollRecord[]
  conductedReviews          PerformanceReview[]      @relation("ConductedReviews")
  performanceReviews        PerformanceReview[]      @relation("StaffReviews")
  schemesOfWork             SchemeOfWork[]           @relation("TeacherSchemes")
  staffAttendanceLogs       StaffAttendanceLog[]
  staffDocuments            StaffDocument[]
  staffAllowances           StaffAllowance[]
  staffDeductions           StaffDeduction[]
  approvedRequisitions      StockRequisition[]       @relation("ApprovedBy")
  inventoryRequisitions     StockRequisition[]       @relation("RequestedBy")
  subjectAssignments        SubjectAssignment[]
  summativeResultHistories  SummativeResultHistory[] @relation("ChangedBy")
  recordedResults           SummativeResult[]        @relation("RecordedResults")
  approvedTests             SummativeTest[]          @relation("ApprovedTests")
  createdTests              SummativeTest[]          @relation("CreatedTests")
  submittedTests            SummativeTest[]          @relation("SubmittedTests")
  sentMessages              SupportMessage[]         @relation("SentMessages")
  notifications             UserNotification[]        @relation("UserNotifications")
  assignedTickets           SupportTicket[]          @relation("AssignedTickets")
  tickets                   SupportTicket[]          @relation("UserTickets")
  createdTermConfigs        TermConfig[]
  assessedValues            ValuesAssessment[]       @relation("AssessorValues")
  pushSubscriptions         PushSubscription[]       @relation("UserPushSubscriptions")


  @@map("users")
  // ── Performance indexes ─────────────────────────────────────────────────────────────────
  @@index([role, archived, status])
  @@index([archived])
  @@index([status, archived])
}

model School {
  id                  String              @id @default(uuid())
  name                String              @unique
  registrationNo      String?             @unique
  address             String?
  county              String?
  subCounty           String?
  ward                String?
  phone               String?
  email               String?
  website             String?
  principalName       String?
  principalPhone      String?
  logoUrl             String?
  faviconUrl          String?
  schoolType          String?
  motto               String?
  vision              String?
  mission             String?
  admissionFormatType AdmissionFormatType @default(BRANCH_PREFIX_START)
  branchSeparator     String              @default("-")
  active              Boolean             @default(true)
  status              String              @default("ACTIVE")
  curriculumType      CurriculumType      @default(CBC_AND_EXAM)
  assessmentMode      AssessmentMode      @default(MIXED)
  customGradingScale  Json?
  archived            Boolean             @default(false)
  archivedAt          DateTime?
  archivedBy          String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  stampUrl            String?
  latitude            Float?
  longitude           Float?
  brandColor          String?
  welcomeMessage      String?
  welcomeTitle        String?
  onboardingMessage   String?
  onboardingTitle     String?
  primaryColor        String?
  secondaryColor      String?
  accentColor1        String?
  accentColor2        String?
  kraPin              String?
  vatNumber           String?
  etimsConfig         Json?
  nemisConfig         Json?

  @@index([kraPin])
  @@index([county])
  @@map("schools")
}

model AdmissionSequence {
  id           String    @id @default(uuid())
  academicYear Int       @unique
  currentValue Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archived     Boolean   @default(false)
  archivedAt   DateTime?
  archivedBy   String?

  @@index([academicYear])
  @@map("admission_sequences")
}

model StaffSequence {
  id           String    @id @default(uuid())
  currentValue Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archived     Boolean   @default(false)
  archivedAt   DateTime?
  archivedBy   String?

  @@map("staff_sequences")
}

model Stream {
  id         String    @id @default(uuid())
  name       String    @unique
  active     Boolean   @default(true)
  archived   Boolean   @default(false)
  archivedAt DateTime?
  archivedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([name])
  @@map("streams")
}

model Notice {
  id             String    @id @default(uuid())
  createdById    String?
  title          String
  content        String
  category       String?
  priority       String    @default("NORMAL")
  status         String    @default("PUBLISHED")
  targetAudience String?
  publishedAt    DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archived       Boolean   @default(false)
  archivedAt     DateTime?
  archivedBy     String?
  createdBy      User?     @relation("NoticeAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([status, publishedAt])
  @@index([archived])
  @@map("notices")
}

model Class {
  id              String            @id @default(uuid())
  classCode       String            @unique
  name            String
  grade           String
  stream          String?
  teacherId       String?
  academicYear    Int               @default(2025)
  term            Term              @default(TERM_1)
  capacity        Int               @default(40)
  room            String?
  active          Boolean           @default(true)
  archived        Boolean           @default(false)
  archivedAt      DateTime?
  archivedBy      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  institutionType InstitutionType   @default(PRIMARY_CBC)
  assets          AssetAssignment[] @relation("AssetClass")
  attendances     Attendance[]
  enrollments     ClassEnrollment[]
  facilities      ClassFacility[]
  schedules       ClassSchedule[]
  teacher         User?             @relation("ClassTeacher", fields: [teacherId], references: [id])

  @@unique([grade, stream, academicYear, term])
  @@index([institutionType, grade, stream])
  @@index([teacherId])
  @@index([grade, stream])
  @@map("classes")
}

model ClassSchedule {
  id             String        @id @default(uuid())
  classId        String
  subject        String
  day            String
  startTime      String
  endTime        String
  room           String?
  teacherId      String?
  semester       String?
  academicYear   Int           @default(2025)
  notes          String?
  active         Boolean       @default(true)
  archived       Boolean       @default(false)
  archivedAt     DateTime?
  archivedBy     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  learningAreaId String?
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  learningArea   LearningArea? @relation(fields: [learningAreaId], references: [id])
  teacher        User?         @relation("TeacherSchedules", fields: [teacherId], references: [id])

  @@index([classId])
  @@index([day])
  @@index([subject])
  @@map("class_schedules")
}

model ClassFacility {
  id                  String    @id @default(uuid())
  classId             String
  facilityName        String
  facilityType        String
  quantity            Int       @default(1)
  condition           String    @default("FUNCTIONAL")
  maintenanceRequired Boolean   @default(false)
  lastMaintenance     DateTime?
  notes               String?
  active              Boolean   @default(true)
  archived            Boolean   @default(false)
  archivedAt          DateTime?
  archivedBy          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  class               Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([facilityType])
  @@index([condition])
  @@map("class_facilities")
}

model ClassEnrollment {
  id         String    @id @default(uuid())
  classId    String
  learnerId  String
  enrolledAt DateTime  @default(now())
  active     Boolean   @default(true)
  archived   Boolean   @default(false)
  archivedAt DateTime?
  archivedBy String?
  class      Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  learner    Learner   @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([classId, learnerId])
  @@index([classId])
  @@index([learnerId])
  @@index([learnerId, active])
  @@index([classId, active])
  @@map("class_enrollments")
}

model Learner {
  id                     String                    @id @default(uuid())
  admissionNumber        String                    @unique
  firstName              String
  lastName               String
  middleName             String?
  dateOfBirth            DateTime
  gender                 Gender
  photoUrl               String?
  photoPublicId          String?
  grade                  String
  stream                 String?
  parentId               String?
  guardianName           String?
  guardianPhone          String?
  guardianEmail          String?
  medicalConditions      String?
  allergies              String?
  emergencyContact       String?
  emergencyPhone         String?
  bloodGroup             String?
  address                String?
  county                 String?
  subCounty              String?
  status                 LearnerStatus             @default(ACTIVE)
  admissionDate          DateTime                  @default(now())
  exitDate               DateTime?
  exitReason             String?
  previousSchool         String?
  religion               String?
  specialNeeds           String?
  isTransportStudent     Boolean                   @default(false)
  idCardIssued           DateTime?
  idCardExpiry           DateTime?
  idCardNumber           String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  createdBy              String?
  updatedBy              String?
  archived               Boolean                   @default(false)
  archivedAt             DateTime?
  archivedBy             String?
  fatherName             String?
  fatherPhone            String?
  fatherEmail            String?
  fatherDeceased         Boolean                   @default(false)
  motherName             String?
  motherPhone            String?
  motherEmail            String?
  motherDeceased         Boolean                   @default(false)
  guardianRelation       String?
  primaryContactType     String?
  primaryContactName     String?
  primaryContactPhone    String?
  primaryContactEmail    String?
  institutionType        InstitutionType           @default(PRIMARY_CBC)
  pathwayId              String?
  upiNumber              String?                   @unique
  smsAudits              AssessmentSmsAudit[]      @relation("LearnerSmsAudits")
  attendances            Attendance[]
  biometricCredentials   BiometricCredential[]
  enrollments            ClassEnrollment[]
  coCurricularActivities CoCurricularActivity[]    @relation("LearnerCoCurricular")
  coreCompetencies       CoreCompetency[]          @relation("LearnerCoreCompetencies")
  feeInvoices            FeeInvoice[]              @relation("LearnerInvoices")
  formativeAssessments   FormativeAssessment[]
  subjectSelections      LearnerSubjectSelection[]
  parent                 User?                     @relation("ParentLearners", fields: [parentId], references: [id])
  pathway                Pathway?                  @relation(fields: [pathwayId], references: [id])
  lmsEnrollments         LMSEnrollment[]           @relation("LMSEnrolledLearners")
  summativeResults       SummativeResult[]
  reportComments         TermlyReportComment[]     @relation("LearnerReportComments")
  valuesAssessments      ValuesAssessment[]        @relation("LearnerValues")

  @@index([admissionNumber])
  @@index([parentId])
  @@index([primaryContactType])
  @@index([institutionType, grade, stream])
  @@index([institutionType, pathwayId])
  @@index([grade, stream])
  @@index([status])
  @@index([grade, status, archived])
  @@index([archived])

  @@map("learners")
}

model Pathway {
  id            String            @id @default(uuid())
  code          String            @unique
  name          String
  description   String?
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  learners      Learner[]
  learningAreas LearningArea[]
  categories    SubjectCategory[]

  @@map("pathways")
}

model SubjectCategory {
  id            String         @id @default(uuid())
  pathwayId     String
  code          String
  name          String
  description   String?
  minSelect     Int            @default(0)
  maxSelect     Int?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  learningAreas LearningArea[]
  pathway       Pathway        @relation(fields: [pathwayId], references: [id], onDelete: Cascade)

  @@unique([pathwayId, code])
  @@index([pathwayId])
  @@map("subject_categories")
}

model LearnerSubjectSelection {
  id             String       @id @default(uuid())
  learnerId      String
  learningAreaId String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  learner        Learner      @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  learningArea   LearningArea @relation(fields: [learningAreaId], references: [id], onDelete: Cascade)

  @@unique([learnerId, learningAreaId])
  @@index([learnerId])
  @@index([learningAreaId])
  @@map("learner_subject_selections")
}

model Attendance {
  id         String           @id @default(uuid())
  learnerId  String
  classId    String?
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  remarks    String?
  markedAt   DateTime         @default(now())
  markedBy   String
  archived   Boolean          @default(false)
  archivedAt DateTime?
  archivedBy String?
  class      Class?           @relation(fields: [classId], references: [id])
  learner    Learner          @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  teacher    User             @relation("AttendanceMarker", fields: [markedBy], references: [id])

  @@unique([learnerId, date])
  @@index([date])
  @@index([learnerId])
  @@index([classId])
  @@index([status])
  @@map("attendances")
}

model FormativeAssessment {
  id               String                  @id @default(uuid())
  learnerId        String
  term             Term                    @default(TERM_1)
  academicYear     Int                     @default(2026)
  learningArea     String
  strand           String?
  subStrand        String?
  overallRating    RubricRating
  detailedRating   DetailedRubricRating?
  points           Int?
  percentage       Float?
  exceedingCount   Int                     @default(0)
  meetingCount     Int                     @default(0)
  approachingCount Int                     @default(0)
  belowCount       Int                     @default(0)
  strengths        String?
  areasImprovement String?
  remarks          String?
  recommendations  String?
  teacherId        String
  type             FormativeAssessmentType @default(OPENER)
  status           AssessmentStatus        @default(DRAFT)
  title            String?
  date             DateTime?               @default(now())
  maxScore         Float?
  weight           Float                   @default(1.0)
  locked           Boolean                 @default(false)
  lockedAt         DateTime?
  lockedBy         String?
  archived         Boolean                 @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  learningAreaId   String?
  levelId          String?                 @map("level_id")
  learner          Learner                 @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  learningAreaRef  LearningArea?           @relation(fields: [learningAreaId], references: [id])
  level            GradingRange?           @relation(fields: [levelId], references: [id])
  teacher          User                    @relation("TeacherFormativeAssessments", fields: [teacherId], references: [id])

  @@unique([learnerId, term, academicYear, learningArea, type, title])
  @@index([learnerId])
  @@index([teacherId])
  @@index([term, academicYear])
  @@index([learningArea])
  @@index([learningAreaId])
  // Dashboard: count({ status:'DRAFT', archived:false })
  @@index([status, archived])
  @@index([archived])

  @@map("formative_assessments")
}

model SummativeTest {
  id              String             @id @default(uuid())
  title           String
  learningArea    String
  term            Term               @default(TERM_1)
  academicYear    Int                @default(2026)
  grade           String
  testDate        DateTime           @db.Date
  totalMarks      Int
  passMarks       Int
  duration        Int?
  description     String?
  instructions    String?
  createdBy       String
  published       Boolean            @default(false)
  active          Boolean            @default(true)
  status          AssessmentStatus   @default(DRAFT)
  curriculum      CurriculumType     @default(CBC_AND_EXAM)
  weight          Float              @default(100.0)
  locked          Boolean            @default(false)
  lockedAt        DateTime?
  lockedBy        String?
  statusHistory   Json[]             @default([])
  submittedBy     String?
  submittedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  scaleId         String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  archived        Boolean            @default(false)
  archivedAt      DateTime?
  archivedBy      String?
  learningAreaId  String?
  testType        SummativeTestType?
  results         SummativeResult[]
  approvedByUser  User?              @relation("ApprovedTests", fields: [approvedBy], references: [id])
  creator         User               @relation("CreatedTests", fields: [createdBy], references: [id])
  learningAreaRef LearningArea?      @relation(fields: [learningAreaId], references: [id])
  scale           GradingSystem?     @relation(fields: [scaleId], references: [id])
  submittedByUser User?              @relation("SubmittedTests", fields: [submittedBy], references: [id])
  @@index([testType])
  @@index([grade, learningArea, term])
  @@index([learningAreaId])
  @@index([grade, term, academicYear])
  @@map("summative_tests")
}

model TermConfig {
  id              String    @id @default(uuid())
  academicYear    Int
  term            Term
  startDate       DateTime
  endDate         DateTime
  formativeWeight Float     @default(30.0)
  summativeWeight Float     @default(70.0)
  isActive        Boolean   @default(false)
  isClosed        Boolean   @default(false)
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archived        Boolean   @default(false)
  archivedAt      DateTime?
  archivedBy      String?
  creator         User      @relation(fields: [createdBy], references: [id])

  @@unique([academicYear, term])
  @@map("term_configs")
}

model AggregationConfig {
  id           String                  @id @default(uuid())
  grade        Grade?
  learningArea String?
  type         FormativeAssessmentType
  strategy     AggregationStrategy     @default(SIMPLE_AVERAGE)
  nValue       Int?
  weight       Float                   @default(1.0)
  createdBy    String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  archived     Boolean                 @default(false)
  archivedAt   DateTime?
  archivedBy   String?
  creator      User                    @relation(fields: [createdBy], references: [id])

  @@map("aggregation_configs")
}

model ChangeHistory {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  field      String?
  oldValue   String?
  newValue   String?
  changedBy  String
  changedAt  DateTime @default(now())
  reason     String?
  changer    User     @relation(fields: [changedBy], references: [id])

  @@index([entityType, entityId])
  @@map("change_history")
}

model SummativeResult {
  id               String                   @id @default(uuid())
  testId           String
  learnerId        String
  marksObtained    Int
  percentage       Float
  grade            String
  status           TestStatus
  moderationStatus ModerationStatus         @default(DRAFT)
  position         Int?
  outOf            Int?
  remarks          String?
  teacherComment   String?
  recordedBy       String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  archived         Boolean                  @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  cbcGrade         String?
  levelId          String?                  @map("level_id")
  resultHistory    SummativeResultHistory[]
  learner          Learner                  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  level            GradingRange?            @relation(fields: [levelId], references: [id])
  recorder         User                     @relation("RecordedResults", fields: [recordedBy], references: [id])
  test             SummativeTest            @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, learnerId])
  @@index([moderationStatus])
  @@index([testId])
  @@index([learnerId])
  @@index([grade])
  @@index([status])
  @@index([testId, grade, marksObtained])
  // Dashboard groupBy({ testId }) filters archived:false
  @@index([archived, testId])
  @@map("summative_results")
}

model SummativeResultHistory {
  id              String          @id @default(uuid())
  resultId        String
  action          String
  field           String?
  oldValue        String?
  newValue        String?
  changedBy       String
  changeTimestamp DateTime        @default(now())
  reason          String?
  changer         User            @relation("ChangedBy", fields: [changedBy], references: [id])
  result          SummativeResult @relation(fields: [resultId], references: [id])

  @@index([resultId])
  @@index([changedBy])
  @@index([changeTimestamp])
  @@map("summative_result_history")
}

model CoreCompetency {
  id                      String               @id @default(uuid())
  learnerId               String
  term                    Term
  academicYear            Int
  communication           DetailedRubricRating
  communicationComment    String?
  criticalThinking        DetailedRubricRating
  criticalThinkingComment String?
  creativity              DetailedRubricRating
  creativityComment       String?
  collaboration           DetailedRubricRating
  collaborationComment    String?
  citizenship             DetailedRubricRating
  citizenshipComment      String?
  learningToLearn         DetailedRubricRating
  learningToLearnComment  String?
  assessedBy              String
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  archived                Boolean              @default(false)
  archivedAt              DateTime?
  archivedBy              String?
  assessor                User                 @relation("AssessorCoreCompetencies", fields: [assessedBy], references: [id])
  learner                 Learner              @relation("LearnerCoreCompetencies", fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([learnerId, term, academicYear])
  @@index([learnerId])
  @@index([term, academicYear])
  @@map("core_competencies")
}

model ValuesAssessment {
  id             String               @id @default(uuid())
  learnerId      String
  term           Term
  academicYear   Int
  love           DetailedRubricRating
  responsibility DetailedRubricRating
  respect        DetailedRubricRating
  unity          DetailedRubricRating
  peace          DetailedRubricRating
  patriotism     DetailedRubricRating
  integrity      DetailedRubricRating
  comment        String?
  assessedBy     String
