  expectedReturn      DateTime?
  returnedAt          DateTime?
  conditionOnAssigned AssetCondition
  conditionOnReturned AssetCondition?
  notes               String?
  asset               FixedAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedToClass     Class?          @relation("AssetClass", fields: [assignedToClassId], references: [id])
  assignedTo          User?           @relation("AssetUser", fields: [assignedToId], references: [id])

  @@index([assetId])
  @@map("asset_assignments")
}

model SchemeOfWork {
