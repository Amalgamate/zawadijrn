model FixedAsset {
  id             String            @id @default(uuid())
  assetCode      String            @unique
  itemId         String?
  name           String
  description    String?
  serialNumber   String?
  model          String?
  manufacturer   String?
  purchaseDate   DateTime?
  purchaseCost   Decimal?          @db.Decimal(15, 2)
  warrantyExpiry DateTime?
  condition      AssetCondition    @default(NEW)
  location       String?
  currentStoreId String?
  status         String            @default("ACTIVE")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignments    AssetAssignment[]
  currentStore   InventoryStore?   @relation(fields: [currentStoreId], references: [id])
  item           InventoryItem?    @relation(fields: [itemId], references: [id])

  @@index([assetCode])
  @@map("fixed_assets")
}

model AssetAssignment {
  id                  String          @id @default(uuid())
  assetId             String
  assignedToId        String?
  assignedToClassId   String?
  assignedAt          DateTime        @default(now())
  expectedReturn      DateTime?
  returnedAt          DateTime?
  conditionOnAssigned AssetCondition
  conditionOnReturned AssetCondition?
  notes               String?
  asset               FixedAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedToClass     Class?          @relation("AssetClass", fields: [assignedToClassId], references: [id])
  assignedTo          User?           @relation("AssetUser", fields: [assignedToId], references: [id])

  @@index([assetId])
  @@map("asset_assignments")
}

