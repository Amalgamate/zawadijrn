  @@map("inventory_categories")
}

model InventoryStore {
  id            String          @id @default(uuid())
  name          String          @unique
  code          String?
  location      String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  fixedAssets   FixedAsset[]
