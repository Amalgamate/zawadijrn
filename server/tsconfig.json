{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "outDir": "./dist",
    "rootDir": "./src",

    // ── Strictness ──────────────────────────────────────────────────────────
    // strict: true enables the full suite:
    //   strictNullChecks, strictFunctionTypes, strictBindCallApply,
    //   strictPropertyInitialization, noImplicitAny, noImplicitThis, alwaysStrict
    "strict": true,

    // Catch dead variables — safe to enable; the codebase already compiles clean.
    // Convention: prefix intentionally unused params with _ (already followed here).
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    // NOT enabled yet — needs a full compile audit first.
    // Enabling noImplicitReturns across 35+ controllers without checking output
    // risks breaking the build silently on the next deploy.
    // TODO: Run `tsc --noEmit` locally, fix all flagged return paths, then set to true.
    "noImplicitReturns": false,
    // ────────────────────────────────────────────────────────────────────────

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/__tests__",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/examples/**/*",
    "scripts/**/*"
  ]
}
