{
  "name": "zawadi-sms-backend",
  "version": "1.0.0",
  "description": "Zawadi JRN Academy - CBC Grading System Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "dev:ts": "ts-node --transpile-only src/index.ts",
    "kill": "powershell -Command \"Get-NetTCPConnection -LocalPort 5000 -ErrorAction SilentlyContinue | Select-Object -Expand OwningProcess | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }\"",
    "build": "echo '=== BUILD STEP 1: Pre-deploy & Migration Resolution ===' && node scripts/pre-deploy.js && echo '=== BUILD STEP 2: Migrate Deploy ===' && npx prisma migrate deploy && echo '=== BUILD STEP 3: Generate Prisma ===' && npx prisma generate && echo '=== BUILD STEP 4: TypeScript ===' && tsc && echo '=== BUILD COMPLETE ==='",
    "postinstall": "prisma generate",
    "deploy": "npm install && npm run build",
    "start": "node dist/index.js",
    "start:push": "prisma db push --skip-generate && node dist/index.js",
    "db:reset": "prisma migrate reset --force --schema ./prisma/schema.prisma",
    "seed": "ts-node prisma/seed.ts",
    "seed:streams": "ts-node prisma/seed-streams.ts",
    "seed:classes": "ts-node prisma/seed-classes.ts",
    "seed:learning-areas": "ts-node prisma/seed-learning-areas.ts",
    "seed:ss:pathways": "ts-node prisma/seed-ss-pathways.ts",
    "seed:coa": "ts-node scripts/seed-accounting.ts",
    "seed:ss:learning-areas": "ts-node prisma/seed-ss-learning-areas.ts",
    "seed:learners:demo": "ts-node prisma/seed-learners-demo.ts",
    "seed:backfill-streams-classes": "ts-node prisma/seeders/seed-streams-classes.ts",
    "backfill:fee-journal": "ts-node scripts/backfill-fee-payments-to-journal.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "provision": "ts-node src/scripts/provision-school.ts",
    "system-setup": "ts-node src/scripts/setup-system.ts",
    "audit:responses": "node scripts/audit-api-response-format.js",
    "audit:responses:strict": "node scripts/audit-api-response-format.js --fail-on-findings",
    "backup": "node scripts/backup-db.js",
    "backup:auto": "node scripts/backup-db.js --auto",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:security": "ts-node tests/security-validation.test.ts",
    "test:load": "ts-node tests/load-testing.test.ts",
    "test:load:light": "ts-node tests/load-testing.test.ts -- --light",
    "test:phase1": "npm run test:security && npm run test:load",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "demo:create-student": "ts-node scripts/create-demo-student.ts",
    "demo:link-parent": "ts-node scripts/link-demo-learner-to-demo-parent.ts",
    "fix:prod-duplicates": "ts-node scripts/fix-summative-duplicates.ts",
    "fix:prod-migration": "ts-node scripts/fix-summative-duplicates.ts && npx prisma migrate resolve --applied 20260402074726_summative_hardening && npx prisma migrate deploy"
  },
  "keywords": [
    "education",
    "cbc",
    "school-management",
    "kenya",
    "api"
  ],
  "author": "Zawadi JRN Academy",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.6",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.101.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4.17.21",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.9",
    "@types/pino-http": "^5.8.4",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "html-parse-stringify2": "^2.0.2",
    "ioredis": "^5.10.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.13",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.9.1",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.0",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/prop-types": "^15.7.15",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/superagent": "^4.1.20",
    "@types/supertest": "^6.0.3",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0",
    "supabase": "^2.77.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
