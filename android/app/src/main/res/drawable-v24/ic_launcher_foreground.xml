<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground layer for Zawadi SMS.
  This is a placeholder used by the adaptive icon system (API 26+).
  The actual logo bitmap is provided via mipmap/ic_launcher_foreground.png
  generated by: npm run icons

  The 108dp canvas with 72dp safe zone (18dp inset each side) is the
  standard adaptive icon spec. Content should stay within the inner 72dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Zawadi brand purple circle background within safe zone -->
    <path
        android:fillColor="#520050"
        android:pathData="M54,18 A36,36 0 1,1 54,90 A36,36 0 1,1 54,18Z" />

    <!-- Letter Z centered — placeholder until npm run icons replaces this with logo PNG -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M39,36 L69,36 L39,72 L69,72 L69,66 L51,66 L81,30 L39,30 Z" />

</vector>
