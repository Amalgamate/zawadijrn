# ============================================
# ZAWADI SMS — FRONTEND ENVIRONMENT
# ============================================
# Copy this file to .env and fill in your values.
#
# IMPORTANT: This project uses Vite, not Create React App.
# Vite requires variables to be prefixed with VITE_
# Variables prefixed with REACT_APP_ are silently ignored.
# See: https://vitejs.dev/guide/env-and-mode
# ============================================

# ============================================
# API CONNECTION (Required)
# ============================================
# The full base URL of the backend API.
# This is read by src/services/axiosConfig.js
#
# Development (default if omitted — no need to set for local dev):
VITE_API_BASE_URL=http://localhost:5000/api
#
# Production example:
# VITE_API_BASE_URL=https://your-api-domain.com/api

# ============================================
# FALLBACK (Optional — only needed if VITE_API_BASE_URL is not set)
# ============================================
# Secondary variable checked by axiosConfig.js before falling back to auto-discovery.
# Leave commented out unless you have a specific reason to use it instead.
# VITE_API_URL=http://localhost:5000/api

# ============================================
# NOTES
# ============================================
# - The frontend port (3000) is hardcoded in vite.config.js — no env var needed.
# - If neither VITE_API_BASE_URL nor VITE_API_URL is set, axiosConfig.js will:
#     • On localhost  → use http://localhost:5000/api  (fine for local dev)
#     • On any other host → use window.location.origin + /api  (assumes reverse proxy)
# - For backend environment variables, see /server/.env.example
