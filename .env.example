# =========================================================================
# ZAWADI SMS — UNIFIED ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy this file to .env and fill in your values.
# Use this root .env for frontend configuration and top-level orchestration.
# Note: For detailed backend configuration, see /server/.env.example
# =========================================================================

# -------------------------------------------------------------------------
# 1. FRONTEND CONFIGURATION (Vite)
# -------------------------------------------------------------------------
# Variables must be prefixed with VITE_ to be accessible in the frontend code.

# The full base URL of the backend API.
VITE_API_URL=http://localhost:5000/api

# The port the VITE dev server should run on (default: 3000)
PORT=3000

# Skip binary OTP checks during development (Optional: true/false)
VITE_SKIP_OTP=true

# -------------------------------------------------------------------------
# 2. DOCKER / ORCHESTRATION CONFIGURATION (Shared)
# -------------------------------------------------------------------------
# These variables are used by docker-compose.yml to set up the DB and Backend.

# Database Credentials
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=zawadi_sms

# Authentication
# Generate a strong secret: openssl rand -base64 32
# Required by backend container in docker-compose.
JWT_SECRET=your_jwt_secret_minimum_32_characters_long

# Logging level (error, warn, info, debug, trace)
LOG_LEVEL=info

# -------------------------------------------------------------------------
# 3. BACKEND QUICK LINKS
# -------------------------------------------------------------------------
# The backend resides in /server and has its own extensive .env.example
# Common backend vars if running via top-level scripts:
NODE_ENV=development
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public
